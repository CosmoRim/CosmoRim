<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<ThingDef Name="CosRimAirlockBase" ParentName="CosRimDoorBase" Abstract="True">
		<description>Powered doors with automatic opening, not easy to damage, and airtight while closed. Minimal slowdown on pawns passing through.</description>
		<thingClass>TabulaRasa.Building_MultiMoverDoor</thingClass>
		<graphicData>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<statBases>
			<WorkToBuild>2000</WorkToBuild>
			<MaxHitPoints>750</MaxHitPoints>
			<Flammability>0.1</Flammability>
		</statBases>
		<building>
			<poweredDoorOpenSpeedFactor>4</poweredDoorOpenSpeedFactor>
			<unpoweredDoorOpenSpeedFactor>2</unpoweredDoorOpenSpeedFactor>
			<unpoweredDoorCloseSpeedFactor>2</unpoweredDoorCloseSpeedFactor>
			<isAirtight>true</isAirtight>
			<blueprintClass>Blueprint_Build</blueprintClass>
			<isSupportDoor>true</isSupportDoor>
			<blueprintGraphicData>
				<graphicClass>Graphic_Multi</graphicClass>
				<shaderType>EdgeDetect</shaderType>
				<drawSize>(3, 3)</drawSize>
			</blueprintGraphicData>
			<doorTopGraphic>
				<graphicClass>Graphic_Multi</graphicClass>
				<shaderType>CutoutComplex</shaderType>
				<drawSize>(3, 3)</drawSize>
			</doorTopGraphic>
			<doorSupportGraphic>
				<graphicClass>Graphic_Multi</graphicClass>
				<shaderType>CutoutComplex</shaderType>
				<drawSize>(3, 3)</drawSize>
			</doorSupportGraphic>
			<soundDoorOpenPowered>SecurityDoor_Open</soundDoorOpenPowered>
			<soundDoorClosePowered>SecurityDoor_BeginClosing</soundDoorClosePowered>
			<soundDoorOpenManual>SecurityDoor_Open</soundDoorOpenManual>
			<soundDoorCloseManual>SecurityDoor_BeginClosing</soundDoorCloseManual>
			<soundDoorCloseEnd>SecurityDoor_EndClosing</soundDoorCloseEnd>
		</building>
		<stuffCategories Inherit="False">
			<li>Metallic</li>
		</stuffCategories>
		<costStuffCount>15</costStuffCount>
		<costList Inherit="False">
			<Plasteel>15</Plasteel>
			<ComponentSpacer>1</ComponentSpacer>
		</costList>
		<modExtensions>
			<li Class="TabulaRasa.DefModExt_SubcategoryDisplay">
				<subcategories>
					<li>Airlocks</li>
				</subcategories>
			</li>
		</modExtensions>
	</ThingDef>

